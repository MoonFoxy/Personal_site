---
import AppLauncher from "./AppLauncher.astro";
import EmailWindow from "./EmailWindow.astro";
import GitHubWindow from "./GitHubWindow.astro";
import ServiceWindow from "./ServiceWindow.astro";
import SettingsWindow from "./SettingsWindow.astro";
import OsIcon from "./OsIcon.astro";
---

<div class="os-shell" data-os-shell>
    <div
        class="boot-overlay"
        data-boot-overlay
        role="status"
        aria-live="polite"
        aria-label="Загрузка Illyune OS"
        data-i18n-aria="boot.aria"
    >
        <div class="boot-panel">
            <div
                class="boot-progress"
                data-boot-progress
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                aria-label="Прогресс загрузки"
                data-i18n-aria="boot.progress"
            >
                <span class="boot-progress__fill" aria-hidden="true"></span>
            </div>
        </div>
    </div>

    <header
        class="system-bar"
        aria-label="Системная панель"
        data-i18n-aria="system.aria"
        data-system-bar
    >
        <div class="system-group system-group--right">
            <time class="system-cell system-cell--date" data-local-date datetime="">--.--.----</time
            >
            <time class="system-cell system-cell--clock" data-local-clock datetime="">
                <OsIcon name="clock" size={16} />
                <span data-local-clock-value>--:--</span>
            </time>
        </div>
    </header>

    <section class="window-layer" aria-label="Открытые приложения" data-i18n-aria="windows.aria">
        <ServiceWindow
            appId="telegram"
            displayName="Ilya Balakirev"
            handle="@MoonFoxy"
            title="Telegram"
            bootAvatar
        />

        <GitHubWindow />

        <ServiceWindow
            appId="discord"
            displayName="Illyune"
            handle="moonfoxy"
            title="Discord Profile"
        />

        <ServiceWindow appId="x" displayName="Illyune" handle="@_MoonFoxy" title="X Profile" />

        <EmailWindow />

        <SettingsWindow />
    </section>

    <AppLauncher />
</div>

<style is:global>
    .os-shell {
        --os-ink: #101515;
        --os-paper: #f7f2e8;
        --os-paper-warm: #f5edcf;
        --os-surface: #edf5f6;
        --os-surface-deep: #d5e6e9;
        --os-highlight: #ffffff;
        --os-mid: #889895;
        --os-accent: #2eb9aa;
        --os-accent-dark: #147f78;
        --os-font: Tahoma, "MS Sans Serif", Arial, sans-serif;
        --os-pixel-font: "Magdalena", "MS Sans Serif", Tahoma, sans-serif;
        --os-display-font: "NeoplantaBG", "Bodoni 72", "Iowan Old Style", "Times New Roman", serif;
        --os-label-font: Tahoma, "MS Sans Serif", Arial, sans-serif;
        --os-small-font: Tahoma, "MS Sans Serif", Arial, sans-serif;
        --os-top-height: 32px;
        --os-launcher-height: 80px;
        position: absolute;
        z-index: 30;
        inset: 0;
        color: var(--os-ink);
        font-family: var(--os-font);
        font-size: 12px;
        font-synthesis: none;
        line-height: 1.35;
        pointer-events: none;
    }

    .os-shell *,
    .os-shell *::before,
    .os-shell *::after {
        box-sizing: border-box;
    }

    .boot-overlay {
        position: fixed;
        z-index: 1000;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 1rem;
        background: #f4ede2;
        pointer-events: auto;
        animation: boot-failsafe 1ms 4s forwards;
        transition:
            opacity 180ms steps(3, end),
            visibility 180ms steps(3, end);
    }

    .boot-overlay[hidden] {
        display: none;
    }

    .boot-overlay.is-leaving {
        visibility: hidden;
        opacity: 0;
    }

    .boot-panel {
        position: relative;
        width: min(23rem, calc(100vw - 2rem));
        padding: 0.48rem;
        border: 1px solid var(--os-ink);
        border-radius: 6px;
        background: var(--os-paper);
        box-shadow:
            inset 1px 1px 0 var(--os-highlight),
            inset -1px -1px 0 var(--os-mid);
    }

    .launcher {
        isolation: isolate;
    }

    .launcher::before {
        position: absolute;
        z-index: -1;
        inset: 4px -6px -6px 4px;
        border-radius: 0 0 6px 0;
        background-image: radial-gradient(
            circle at 0 0,
            rgba(8, 22, 23, 0.78) 0 0.65px,
            transparent 0.78px
        );
        background-size: 2px 2px;
        content: "";
        pointer-events: none;
    }

    .boot-progress {
        position: relative;
        height: 21px;
        overflow: hidden;
        border: 1px solid var(--os-ink);
        background: #f8f7ed;
        box-shadow:
            inset 1px 1px 0 var(--os-mid),
            inset -1px -1px 0 var(--os-highlight);
    }

    .boot-progress__fill {
        display: block;
        width: var(--boot-progress, 0%);
        height: 100%;
        min-width: 0;
        background: repeating-linear-gradient(
            90deg,
            var(--os-accent) 0 8px,
            #8cdbcf 8px 9px,
            transparent 9px 11px
        );
        transition: width 100ms steps(20, end);
    }

    .system-bar {
        position: absolute;
        z-index: 60;
        top: env(safe-area-inset-top);
        right: env(safe-area-inset-right);
        left: auto;
        display: flex;
        align-items: flex-start;
        justify-content: flex-end;
        pointer-events: none;
    }

    .system-group {
        display: flex;
        align-items: stretch;
    }

    .system-cell {
        position: relative;
        display: inline-flex;
        min-height: 31px;
        align-items: center;
        gap: 0.35rem;
        padding: 0 9px;
        border: 1px solid var(--os-ink);
        background: #f9f0e9;
        box-shadow: none;
        padding: 9px 10px 8px;
        font-family: var(--os-pixel-font);
        font-size: 16px;
        font-weight: 400;
        letter-spacing: 0;
        line-height: 13.92px;
        white-space: nowrap;
    }

    .system-group .system-cell + .system-cell {
        margin-left: -1px;
    }

    .system-cell--date,
    .system-cell--clock {
        font-variant-numeric: tabular-nums;
    }

    .system-cell,
    .settings-tabs button,
    .settings-version {
        font-kerning: none;
        font-variant-ligatures: none;
        text-rendering: optimizeSpeed;
    }

    .system-cell .os-icon {
        width: 16px;
        height: 16px;
    }

    .window-layer {
        position: absolute;
        z-index: 70;
        inset: calc(var(--os-top-height) + env(safe-area-inset-top)) 0
            calc(var(--os-launcher-height) + env(safe-area-inset-bottom));
        pointer-events: none;
    }

    .os-window-stage {
        position: absolute;
        width: min(var(--window-width), calc(100vw - 24px));
        height: min(
            var(--window-height),
            calc(100dvh - var(--os-top-height) - var(--os-launcher-height) - 20px)
        );
        min-height: 250px;
        overflow: visible;
        outline: none;
        pointer-events: auto;
    }

    .os-window-stage:focus,
    .os-window-stage:focus-visible {
        outline: none !important;
    }

    .os-window-stage[hidden] {
        display: none;
    }

    .os-window-shadow {
        position: absolute;
        z-index: 0;
        inset: 4px -6px -6px 4px;
        border-radius: 0 0 6px 0;
        background-image: radial-gradient(
            circle at 0 0,
            rgba(8, 22, 23, 0.78) 0 0.65px,
            transparent 0.78px
        );
        background-size: 2px 2px;
        content: "";
        pointer-events: none;
    }

    .os-window {
        position: relative;
        z-index: 1;
        display: flex;
        width: 100%;
        height: 100%;
        min-height: inherit;
        flex-direction: column;
        overflow: visible;
        padding: 6px;
        border: 1px solid var(--os-ink);
        border-radius: 6px;
        background: #f9f0e9;
        box-shadow: none;
    }

    .os-window-stage--telegram,
    .os-window-stage--discord,
    .os-window-stage--x {
        --window-width: 392px;
        --window-height: 314px;
    }

    .os-window-stage--telegram {
        top: 9%;
        left: 9%;
    }

    .os-window-stage--github {
        --window-width: 620px;
        --window-height: 520px;
        top: 8%;
        right: 12%;
    }

    .os-window-stage--discord {
        top: 16%;
        left: 28%;
    }

    .os-window-stage--x {
        top: 9%;
        right: 7%;
    }

    .os-window-stage--email {
        --window-width: 520px;
        --window-height: 430px;
        top: 14%;
        left: 20%;
    }

    .os-window-stage--settings {
        --window-width: 520px;
        --window-height: 380px;
        top: 18%;
        left: calc(50% - 260px);
    }

    .window-titlebar {
        display: grid;
        min-height: 30px;
        flex: 0 0 auto;
        grid-template-columns: 18px 16px 1fr;
        /* The 16px title must stay on a whole pixel row. Vertical centering
           in this 19px content track positioned it at a .5px coordinate. */
        align-items: start;
        gap: 2px;
        margin: -6px -6px 0;
        padding: 6px 6px 5px;
        border: 0;
        border-radius: 5px 5px 0 0;
        background: #f9f0e9;
        cursor: move;
        touch-action: none;
        user-select: none;
    }

    .window-titlebar h2 {
        margin: 0;
        min-width: 0;
        padding-right: 1px;
        font-family: var(--os-display-font);
        font-size: 16px;
        font-weight: 400;
        font-kerning: none;
        font-variant-ligatures: none;
        letter-spacing: -1px;
        line-height: 16px;
        text-align: right;
        text-rendering: optimizeSpeed;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .window-close {
        display: grid;
        width: 18px;
        height: 18px;
        margin: 0;
        padding: 0 0 2px;
        place-items: center;
        border: 0;
        border-radius: 2px;
        background: transparent;
        color: var(--os-ink);
        font: 16px/1 var(--os-font);
        cursor: pointer;
    }

    .window-close:hover,
    .window-close:focus-visible {
        outline: 1px dotted var(--os-ink);
        outline-offset: -3px;
        background: var(--os-paper);
    }

    .window-close:active {
        color: var(--os-paper);
        background: var(--os-ink);
    }

    .window-body {
        min-height: 0;
        flex: 1 1 auto;
        overflow: auto;
        margin: 0;
        border: 1px solid var(--os-ink);
        background: var(--os-paper);
        box-shadow: none;
    }

    .os-scrollbar {
        scrollbar-color: var(--os-surface-deep) var(--os-paper);
        scrollbar-width: auto;
    }

    .os-scrollbar::-webkit-scrollbar {
        width: 15px;
        height: 15px;
    }

    .os-scrollbar::-webkit-scrollbar-track {
        border-left: 1px solid var(--os-ink);
        background:
            radial-gradient(circle, var(--os-mid) 0 0.55px, transparent 0.7px) 0 0 / 2px 2px,
            var(--os-paper);
    }

    .os-scrollbar::-webkit-scrollbar-thumb {
        border: 1px solid var(--os-ink);
        background: var(--os-surface-deep);
        box-shadow:
            inset 1px 1px 0 var(--os-highlight),
            inset -1px -1px 0 var(--os-mid);
    }

    .profile-avatar {
        display: block;
        object-fit: cover;
        object-position: 52% 48%;
        image-rendering: auto;
    }

    .profile-avatar--large {
        width: 72px;
        height: 72px;
        border: 2px solid var(--os-ink);
        border-radius: 50%;
        background: var(--os-surface-deep);
    }

    .os-command {
        display: flex;
        min-height: 34px;
        align-items: center;
        justify-content: center;
        margin: 8px;
        padding: 6px 8px;
        border: 1px solid var(--os-ink);
        border-radius: 3px;
        background: var(--os-surface);
        box-shadow:
            inset 1px 1px 0 var(--os-highlight),
            inset -1px -1px 0 var(--os-mid);
        color: var(--os-ink);
        font: 700 11px/1.1 var(--os-font);
        text-align: center;
        text-decoration: none;
    }

    .os-command:hover,
    .os-command:focus-visible {
        outline: 1px dotted var(--os-ink);
        outline-offset: -5px;
        background: #fffdf2;
    }

    .os-command:active {
        box-shadow:
            inset 1px 1px 0 var(--os-mid),
            inset -1px -1px 0 var(--os-highlight);
        transform: translate(2px, 2px);
    }

    .profile-bio {
        margin: 5px 0 0;
        line-height: 1.32;
    }

    .window-body--github {
        background: #f8f6ed;
    }

    .github-profile {
        display: grid;
        grid-template-columns: 96px 1fr;
        gap: 10px;
        padding: 10px;
        border-bottom: 1px solid var(--os-ink);
    }

    .profile-avatar--github {
        width: 96px;
        height: 96px;
        border: 1px solid var(--os-ink);
        border-radius: 3px;
        background: var(--os-surface-deep);
    }

    .github-profile h3 {
        margin: 2px 0 0;
        font: 700 19px/1.1 var(--os-font);
    }

    .github-profile__copy > p:first-of-type {
        margin: 0 0 6px;
        color: #576461;
        font-family: var(--os-font);
    }

    .github-profile__copy > p {
        margin: 5px 0;
    }

    .github-meta {
        min-height: 1em;
        color: #576461;
        font-size: 10px;
    }

    .github-state {
        margin: 8px 10px 0;
        padding: 6px 7px;
        border: 1px dotted var(--os-mid);
        background: var(--os-surface);
        font: 11px/1.3 var(--os-font);
    }

    .github-repository-section {
        padding: 9px 10px 2px;
    }

    .github-repository-section > h3 {
        margin: 0 0 6px;
        font: 700 13px/1 var(--os-font);
        text-transform: uppercase;
    }

    .github-repositories {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 8px;
    }

    .github-repositories:empty::after {
        grid-column: 1 / -1;
        min-height: 42px;
        border: 1px dashed var(--os-mid);
        content: "";
    }

    .github-repositories > .github-repository {
        display: flex;
        min-width: 0;
        min-height: 92px;
        flex-direction: column;
        gap: 5px;
        padding: 8px;
        border: 2px solid var(--os-ink);
        background: var(--os-surface);
        box-shadow:
            inset 1px 1px 0 var(--os-highlight),
            inset -1px -1px 0 var(--os-mid);
    }

    .github-repositories > .github-repository a {
        display: block;
        padding-bottom: 4px;
        border-bottom: 1px solid var(--os-ink);
        color: var(--os-accent-dark);
        overflow-wrap: anywhere;
    }

    .github-repositories > .github-repository p {
        display: -webkit-box;
        overflow: hidden;
        margin: 0;
        font-size: 10px;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
    }

    .github-repositories > .github-repository .github-repository__meta {
        display: flex;
        margin-top: auto;
        justify-content: space-between;
        gap: 4px;
        color: #576461;
        font-size: 9px;
    }

    .window-body--telegram,
    .window-body--discord,
    .window-body--x {
        display: flex;
        flex-direction: column;
        background: var(--os-paper);
    }

    .service-profile {
        display: grid;
        grid-template-columns: 72px minmax(0, 1fr);
        gap: 10px;
        align-items: center;
        min-height: 134px;
        margin: 8px 8px 0;
        padding: 10px;
        border: 1px solid var(--os-ink);
        background: var(--os-paper);
    }

    .service-profile--telegram {
        border-top: 4px solid #229ed9;
    }

    .service-profile--discord {
        border-top: 4px solid #5865f2;
    }

    .service-profile--x {
        border-top: 4px solid #111;
    }

    .service-profile h3 {
        margin: 0;
        font: 700 16px/1.15 var(--os-font);
    }

    .service-handle {
        margin: 2px 0 0;
        color: #52605e;
    }

    .window-body--telegram .os-command,
    .window-body--discord .os-command,
    .window-body--x .os-command {
        width: auto;
        margin: 8px;
    }

    .window-body--email {
        padding-bottom: 6px;
        background: #f7f4e9;
    }

    .mail-header {
        display: grid;
        grid-template-columns: 58px 1fr;
        gap: 6px;
        padding: 8px 10px;
        border-bottom: 1px solid var(--os-ink);
        background: var(--os-surface-deep);
    }

    .mail-header strong {
        overflow-wrap: anywhere;
    }

    .email-form {
        display: grid;
        gap: 5px;
        padding: 9px 10px;
    }

    .email-form label {
        font-weight: 700;
    }

    .email-form input,
    .email-form textarea {
        width: 100%;
        border: 1px solid var(--os-ink);
        border-radius: 0;
        background: #fffef7;
        box-shadow:
            inset 1px 1px 0 var(--os-mid),
            inset -1px -1px 0 var(--os-highlight);
        color: var(--os-ink);
        font: 13px/1.4 var(--os-font);
    }

    .email-form input {
        min-height: 32px;
        padding: 5px 7px;
    }

    .email-form textarea {
        min-height: 108px;
        resize: vertical;
        padding: 8px;
    }

    .mail-hint {
        margin: 2px 0 0;
        color: #576461;
        font-size: 10px;
    }

    .os-command--button {
        width: 100%;
        margin: 5px 0 0;
        cursor: pointer;
    }

    .window-body--settings {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #f7f5eb;
    }

    .settings-tabs {
        display: grid;
        flex: 0 0 auto;
        grid-template-columns: repeat(2, 1fr);
    }

    .settings-tabs button {
        min-height: 30px;
        border: 0;
        border-bottom: 1px solid var(--os-ink);
        background: var(--os-surface-deep);
        color: var(--os-ink);
        font: 700 16px/16px var(--os-pixel-font);
        text-transform: uppercase;
        cursor: pointer;
    }

    .settings-tabs button + button {
        border-left: 1px solid var(--os-ink);
    }

    .settings-tabs button[aria-selected="true"] {
        border-bottom-color: var(--os-paper);
        background: var(--os-paper);
    }

    .settings-tabs button:focus-visible,
    .segmented-control button:focus-visible,
    .cursor-options button:focus-visible {
        outline: 1px dotted var(--os-ink);
        outline-offset: -4px;
    }

    .settings-panel {
        min-height: 0;
        flex: 1 1 auto;
        overflow: auto;
        padding: 9px 10px 10px;
    }

    .settings-panel[hidden] {
        display: none;
    }

    .settings-group {
        min-width: 0;
        margin: 0 0 8px;
        padding: 8px;
        border: 1px solid var(--os-ink);
        box-shadow: none;
    }

    .settings-group legend {
        padding: 0 5px;
        font: 700 10px/1 var(--os-font);
        text-transform: uppercase;
    }

    .segmented-control {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 5px;
    }

    .segmented-control--three {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .segmented-control button,
    .cursor-options button {
        min-height: 34px;
        border: 1px solid var(--os-ink);
        border-radius: 3px;
        background: var(--os-surface);
        box-shadow:
            inset 1px 1px 0 var(--os-highlight),
            inset -1px -1px 0 var(--os-mid);
        color: var(--os-ink);
        font: 700 11px/1 var(--os-font);
        cursor: pointer;
    }

    .segmented-control button[aria-pressed="true"],
    .cursor-options button[aria-pressed="true"] {
        background: var(--os-ink);
        color: var(--os-paper);
        box-shadow:
            inset 1px 1px 0 #000,
            inset -1px -1px 0 #46514f;
    }

    .settings-time-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .settings-readout {
        display: grid;
        min-height: 68px;
        grid-template-columns: 24px 1fr;
        align-items: center;
        padding: 6px;
        border: 1px solid var(--os-ink);
        box-shadow: none;
    }

    .settings-readout > .os-icon {
        width: 16px;
        height: 16px;
    }

    .settings-readout time {
        font: 700 13px/1 var(--os-font);
        font-variant-numeric: tabular-nums;
    }

    .settings-readout small {
        grid-column: 1 / -1;
        font-size: 10px;
    }

    .settings-version {
        margin-top: auto;
        padding-top: 18px;
        font: 16px/16px var(--os-pixel-font);
        text-align: right;
    }

    .settings-version strong {
        display: block;
        font-weight: 700;
    }

    .cursor-options {
        width: min(100%, 278px);
    }

    .settings-group--cursor {
        margin-bottom: 8px;
    }

    .cursor-options__choices {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .cursor-options button {
        display: grid;
        width: 100%;
        min-height: 64px;
        padding: 6px;
        place-items: center;
    }

    .cursor-preview {
        width: 48px;
        height: 48px;
        background-position: center;
        background-repeat: no-repeat;
        background-size: 48px 48px;
        image-rendering: crisp-edges;
        image-rendering: pixelated;
    }

    .cursor-preview--classic {
        background-image: url("/cursors/jeelh/light/Normal%20Select%20Light.cur");
    }

    .cursor-preview--dark {
        background-image: url("/cursors/jeelh/dark/Normal%20Select.cur");
    }

    .launcher {
        position: absolute;
        z-index: 65;
        right: max(8px, env(safe-area-inset-right));
        bottom: max(0px, env(safe-area-inset-bottom));
        left: max(8px, env(safe-area-inset-left));
        display: grid;
        width: min(480px, calc(100% - 16px));
        height: 71px;
        min-height: 71px;
        grid-template-columns: repeat(6, 80px);
        margin-inline: auto;
        border: 1px solid var(--os-ink);
        border-radius: 4px 4px 0 0;
        overflow: hidden;
        background: #f9f0e9;
        box-shadow: none;
