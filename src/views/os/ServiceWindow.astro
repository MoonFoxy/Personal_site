---
import { Image } from "astro:assets";
import avatar from "../../assets/avatar.png";
import { appById, profileAvatarConfig, type AppId } from "../../models/app-registry";
import AvatarPlaceholder from "./AvatarPlaceholder.astro";
import WindowFrame from "./WindowFrame.astro";

type ServiceAppId = Extract<AppId, "telegram" | "discord" | "x">;

interface Props {
    appId: ServiceAppId;
    displayName: string;
    handle: string;
    title: string;
    bootAvatar?: boolean;
}

const { appId, displayName, handle, title, bootAvatar = false } = Astro.props;
const href = appById(appId)?.href ?? "#";
const avatarUrl = profileAvatarConfig[appId];
---

<WindowFrame
    appId={appId}
    bodyClass={`window-body--${appId} os-scrollbar`}
    closeLabel={`Закрыть ${title}`}
    title={title}
>
    <section class={`service-profile service-profile--${appId}`} aria-labelledby={`${appId}-name`}>
        <div
            class="profile-avatar profile-avatar--large"
            data-avatar-frame
            data-avatar-state="loading"
        >
            <AvatarPlaceholder />
            {
                avatarUrl ? (
                    <img
                        class="profile-avatar__image"
                        src={avatarUrl}
                        alt={`${displayName} avatar`}
                        width="192"
                        height="192"
                        loading="eager"
                        decoding="async"
                        referrerpolicy="no-referrer"
                        data-avatar-image
                        data-boot-avatar={bootAvatar || undefined}
                    />
                ) : (
                    <Image
                        class="profile-avatar__image"
                        src={avatar}
                        alt={`${displayName} avatar`}
                        width={192}
                        height={192}
                        format="webp"
                        quality={84}
                        loading="eager"
                        decoding="async"
                        data-avatar-image
                        data-boot-avatar={bootAvatar || undefined}
                    />
                )
            }
        </div>
        <div class="service-profile__copy">
            <h3 id={`${appId}-name`}>{displayName}</h3>
            <p class="service-handle">{handle}</p>
            <p class="profile-bio" data-i18n={`profile.${appId}.bio`}>
                Публичный профиль и быстрый способ связаться со мной.
            </p>
        </div>
    </section>
    <a class="os-command" href={href} data-i18n="action.open_original">Открыть оригинал</a>
</WindowFrame>
